<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.Sisyphus.RawhideRelay</id>
  <name>Rawhide Relay</name>
  <summary>GTK4 IRC client for Libera.Chat</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0-or-later</project_license>

  <description>
    <p>
      Rawhide Relay is a GTK4 IRC client written in Rust using relm4.
      It provides a clean desktop interface for connecting to Libera.Chat
      with TLS, NickServ authentication, multi-channel chat, and live user lists.
    </p>
    <p>
      It is designed for a fast Linux desktop workflow with a Gruvbox-inspired
      interface and simple channel navigation.
    </p>
  </description>

  <launchable type="desktop-id">rawhide-relay.desktop</launchable>

  <categories>
    <category>Network</category>
    <category>Chat</category>
  </categories>

  <keywords>
    <keyword>IRC</keyword>
    <keyword>Chat</keyword>
    <keyword>Libera</keyword>
    <keyword>Rust</keyword>
    <keyword>GTK</keyword>
  </keywords>

  <developer id="org.sisyphuscode">
    <name>SisyphusCode</name>
  </developer>

  <url type="homepage">https://github.com/SisyphusCode/rawhide-relay</url>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="0.1.0" date="2026-06-21"/>
  </releases>
</component>
